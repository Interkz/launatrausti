# Launatrausti — Environment Configuration
# Copy this file to .env and fill in your values.

# Path to SQLite database file (relative to project root or absolute)
DATABASE_URL=launatrausti.db

# Secret key for session signing / CSRF (generate a random string for production)
SECRET_KEY=change-me-in-production

# Enable debug mode (true/false)
DEBUG=false

# Allowed CORS origins, comma-separated (leave empty to disable CORS)
CORS_ORIGINS=

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
